{
  "name": "scopeglass",
  "version": "0.1.0",
  "description": "DevTools for AGENTS.md: inspect effective instructions, provenance, conflicts, references, and context cost.",
  "keywords": [
    "agents-md",
    "ai-agents",
    "codex",
    "developer-tools",
    "static-analysis"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/cli.js"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "npm@10.9.8",
  "bin": {
    "scopeglass": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/report-v1.json": "./schemas/scopeglass-report-v1.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap --clean --target node22 --platform node",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"*.config.ts\"",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "typecheck": "tsc --noEmit",
    "package:check": "publint && attw --pack .",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run package:check",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "15.0.0",
    "mdast-util-from-markdown": "2.0.3",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@types/mdast": "4.0.4",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
