{
  "name": "scopeglass",
  "version": "0.2.0",
  "description": "DevTools for AGENTS.md: inspect effective instructions, provenance, conflicts, references, and context cost.",
  "keywords": [
    "agents-md",
    "ai-agents",
    "codex",
    "developer-tools",
    "static-analysis"
  ],
  "homepage": "https://github.com/zackabrah/scopeglass#readme",
  "bugs": {
    "url": "https://github.com/zackabrah/scopeglass/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zackabrah/scopeglass.git"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/cli.js"
  ],
  "engines": {
    "node": ">=22.17.0"
  },
  "packageManager": "npm@10.9.8",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "scopeglass": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/report-v1.json": "./schemas/scopeglass-report-v1.schema.json",
    "./schema/check-result-v1.json": "./schemas/scopeglass-check-result-v1.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas",
    "docs",
    "AGENTS.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap --clean --target node22 --platform node",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"*.config.ts\"",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "typecheck": "tsc --noEmit",
    "schema:check": "node scripts/validate-schema.mjs",
    "browser:install": "node node_modules/playwright-core/cli.js install chromium firefox webkit",
    "browser:check": "npm run build && node scripts/browser-qa.mjs",
    "package:pack": "node scripts/pack-package.mjs",
    "package:check": "npm run package:pack && node scripts/verify-package.mjs",
    "release:check": "node scripts/check-release-tag.mjs",
    "release:stage": "node scripts/publish-package.mjs",
    "audit": "npm audit --audit-level=high",
    "audit:signatures": "npm audit signatures",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run schema:check && npm run package:check"
  },
  "dependencies": {
    "commander": "15.0.0",
    "mdast-util-from-markdown": "2.0.3",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@types/mdast": "4.0.4",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "ajv": "8.20.0",
    "axe-core": "4.12.1",
    "eslint": "10.7.0",
    "playwright-core": "1.61.1",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
